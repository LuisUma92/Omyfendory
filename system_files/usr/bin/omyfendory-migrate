#!/bin/bash
# Omyfendory Migrate
# Copies skel configs and Zen extensions to the current user's home.
# Intended for existing installs after `bootc upgrade`.
# Runs as the current user (no sudo).

set -euo pipefail

DRY_RUN=false
if [[ "${1:-}" == "--dry-run" ]]; then
    DRY_RUN=true
fi

TIMESTAMP=$(date +%Y%m%d-%H%M%S)
BACKUP_DIR="$HOME/.config.bak.${TIMESTAMP}"

# ─── Directories to sync from skel ──────────────────────────
SKEL_DIRS=(
    .config/btop
    .config/nvim
    .config/zathura
    .config/hypr
    .config/waybar
    .config/mako
    .config/foot
    .config/uwsm
    .config/starship.toml
    .local/share/omarchy
    .local/share/umas
    .zen
)

echo "Omyfendory Migrate"
echo "==================="
if $DRY_RUN; then
    echo "[DRY RUN] No files will be modified."
    echo ""
fi

# ─── Backup existing configs ─────────────────────────────────
BACKED_UP=()
for item in "${SKEL_DIRS[@]}"; do
    src="/etc/skel/${item}"
    dst="$HOME/${item}"
    if [[ -e "$src" ]] && [[ -e "$dst" ]]; then
        BACKED_UP+=("$item")
    fi
done

if [[ ${#BACKED_UP[@]} -gt 0 ]]; then
    echo "Backing up existing configs to ${BACKUP_DIR}/"
    if ! $DRY_RUN; then
        mkdir -p "$BACKUP_DIR"
    fi
    for item in "${BACKED_UP[@]}"; do
        dst="$HOME/${item}"
        backup_target="${BACKUP_DIR}/${item}"
        if $DRY_RUN; then
            echo "  [backup] ${item}"
        else
            mkdir -p "$(dirname "$backup_target")"
            cp -rf "$dst" "$backup_target"
            echo "  Backed up ${item}"
        fi
    done
    echo ""
fi

# ─── Copy skel configs ───────────────────────────────────────
echo "Syncing configs from /etc/skel..."
SYNCED=0
for item in "${SKEL_DIRS[@]}"; do
    src="/etc/skel/${item}"
    if [[ -e "$src" ]]; then
        dst="$HOME/${item}"
        if $DRY_RUN; then
            echo "  [sync] ${item}"
        else
            mkdir -p "$(dirname "$dst")"
            cp -rf "$src" "$dst"
            echo "  Synced ${item}"
        fi
        ((SYNCED++))
    fi
done

# ─── Copy .bashrc ────────────────────────────────────────────
if [[ -f /etc/skel/.bashrc ]]; then
    if [[ -f "$HOME/.bashrc" ]] && ! $DRY_RUN; then
        mkdir -p "$BACKUP_DIR"
        cp -f "$HOME/.bashrc" "${BACKUP_DIR}/.bashrc"
        echo "  Backed up .bashrc"
    fi
    if $DRY_RUN; then
        echo "  [sync] .bashrc"
    else
        cp -f /etc/skel/.bashrc "$HOME/.bashrc"
        echo "  Synced .bashrc"
    fi
    ((SYNCED++))
fi

# ─── Sync Zen extensions ─────────────────────────────────────
ZEN_EXT_SRC="/usr/share/omyfendory/zen-extensions"
if [[ -d "$ZEN_EXT_SRC" ]] && ls "$ZEN_EXT_SRC"/*.xpi &>/dev/null; then
    ZEN_DIR="$HOME/.zen"
    ZEN_PROFILE=""
    if [[ -f "${ZEN_DIR}/profiles.ini" ]]; then
        ZEN_PROFILE=$(awk -F= '/^\[/{section=$0} /^Default=1/{found=section} /^Path=/{if(found==section) print $2}' "${ZEN_DIR}/profiles.ini" | head -1)
    fi
    if [[ -z "$ZEN_PROFILE" ]]; then
        for d in "${ZEN_DIR}"/*.Default*; do
            if [[ -d "$d" ]]; then
                ZEN_PROFILE=$(basename "$d")
                break
            fi
        done
    fi
    if [[ -n "$ZEN_PROFILE" ]]; then
        ZEN_EXT_DST="${ZEN_DIR}/${ZEN_PROFILE}/extensions"
        EXT_COUNT=$(ls "$ZEN_EXT_SRC"/*.xpi 2>/dev/null | wc -l)
        if $DRY_RUN; then
            echo "  [sync] ${EXT_COUNT} Zen extensions → ${ZEN_PROFILE}/extensions/"
        else
            mkdir -p "$ZEN_EXT_DST"
            cp -f "$ZEN_EXT_SRC"/*.xpi "$ZEN_EXT_DST/"
            echo "  Synced ${EXT_COUNT} Zen extensions to ${ZEN_PROFILE}"
        fi
        ((SYNCED++))
    else
        echo "  Warning: no Zen profile found, skipping extensions"
    fi
fi

# ─── Summary ─────────────────────────────────────────────────
echo ""
echo "Done! ${SYNCED} items synced."
if [[ ${#BACKED_UP[@]} -gt 0 ]]; then
    echo "Previous configs backed up to: ${BACKUP_DIR}/"
fi
if $DRY_RUN; then
    echo ""
    echo "This was a dry run. Run without --dry-run to apply changes."
fi
